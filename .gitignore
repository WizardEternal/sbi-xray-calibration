data/
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ipynb_checkpoints/
*.egg-info/
build/
dist/
sbi-logs/

# ----------------------------------------------------------------------------
# Heavy / regenerable artifacts: checkpoints, datasets, raw benchmark dumps are
# NEVER committed (all rebuildable from config+seed). The final README/RESULTS
# FIGURES are the exception and ARE committed (negations at the bottom) so the
# repo reads as a 90-second skim without running anything.
# ----------------------------------------------------------------------------
*.h5
*.pt
*.pkl
*.ckpt

# trained-flow checkpoints + their metadata (regenerable; some are large)
outputs/models/

# per-level calibration dumps (npz/json/most png) -- regenerable
outputs/calibration/

# detection-benchmark scores/AUC JSONL + working figures -- regenerable
outputs/detect/

# NS-vs-NPE benchmark JSONL + analysis -- regenerable
outputs/ns_bench/

# GO/NO-GO robustness pack: per-variant calibration dumps + figures -- regenerable
# (the summary.jsonl record IS committed below, like the detect markdown tables)
outputs/gonogo/

# ----------------------------------------------------------------------------
# FINAL FIGURES + tables to COMMIT (un-ignored). These are the README/RESULTS
# artifacts; everything heavy above stays ignored. Each negation re-includes a
# specific file from an otherwise-ignored directory (git can descend because the
# directory itself is not match-pruned once we negate a path under it).
# ----------------------------------------------------------------------------

# the money plot (top-level outputs/, not under any ignored subdir)
!outputs/money_plot.png

# Phase-3 calibration figures + the per-level summary.json (the committed
# record behind the calibration table). Re-include the directories so git can
# descend, ignore ALL their contents, then re-include only the specific
# committed PNGs and summary.json (npz stay ignored).
!outputs/calibration/
!outputs/calibration/*/
outputs/calibration/*/*
!outputs/calibration/*/sbc_ranks.png
!outputs/calibration/*/tarp.png
!outputs/calibration/*/coverage_before_after.png
!outputs/calibration/*/summary.json

# Phase-4 detection figures, the AUC / consequence tables, and the per-cell
# results.jsonl (the verifiable record behind the README numbers; per-spectrum
# scores stay out)
!outputs/detect/
outputs/detect/*
!outputs/detect/auc_table.md
!outputs/detect/auc_heatmap.png
!outputs/detect/consequence.md
!outputs/detect/results.jsonl

# GO/NO-GO robustness pack: the one-line-per-variant verdict record (cheap, the
# verifiable evidence behind the ROBUST/FRAGILE/MIXED call) IS committed; the
# per-variant calibration dumps/figures stay ignored. Re-include the dir so git
# can descend, ignore its contents, then re-include only summary.jsonl.
!outputs/gonogo/
outputs/gonogo/*
!outputs/gonogo/summary.jsonl

# NS-vs-NPE benchmark: commit the digested analysis (analysis.md +
# analysis_summary.json), the count-controlled evidence summary, the paired
# gain check, and the per-spectrum log-evidence (the evidence record behind the
# paper's NS table); raw backups/probes/timing logs stay out.
!outputs/ns_bench/
outputs/ns_bench/*
!outputs/ns_bench/analysis.md
!outputs/ns_bench/analysis_summary.json
!outputs/ns_bench/count_controlled.json
!outputs/ns_bench/paired_gain_check.jsonl
!outputs/ns_bench/results.jsonl

# diagnostics figures + tables used in the README (money-panel, detector grid,
# dGamma, recovery scatters, learning curve, de-risk checks, TARP curve, the
# validation summary + learning-curve json). Re-include the directory so git can
# descend, ignore ALL its contents (so stray dumps like a stdout log stay out),
# then re-include ONLY the specific committed files.
!outputs/diagnostics/
outputs/diagnostics/*
!outputs/diagnostics/brems_check.png
!outputs/diagnostics/coverage_money_panel.png
!outputs/diagnostics/detector_auc_grid.png
!outputs/diagnostics/dgamma_silent_failure.png
!outputs/diagnostics/gain_shift_check.png
!outputs/diagnostics/learning_curve_dev.json
!outputs/diagnostics/learning_curve_dev.png
!outputs/diagnostics/npe_recovery_bright.png
!outputs/diagnostics/npe_recovery_faint.png
!outputs/diagnostics/npe_recovery_medium.png
!outputs/diagnostics/tarp_bright_curve.png
!outputs/diagnostics/validation_prod_summary.json

# explicit belt-and-braces ignore for the verbose validation stdout dump (it
# leaked an absolute home path on nearly every line; the numbers live in
# validation_prod_summary.json)
outputs/diagnostics/validation_prod_stdout.txt

# NICER benchmark outputs: commit the small evidence files behind the paper's
# NICER numbers (the detection results.jsonl + the per-level calibration
# summary.json); heavy dumps stay out and are regenerated by the pipeline.
# ns_bench_nicer stays fully ignored.
outputs/detect_nicer/*
!outputs/detect_nicer/results.jsonl
outputs/calibration_nicer/**
!outputs/calibration_nicer/**/
!outputs/calibration_nicer/**/summary.json
outputs/ns_bench_nicer/
